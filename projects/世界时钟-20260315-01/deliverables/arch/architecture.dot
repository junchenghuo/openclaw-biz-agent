digraph WorldClock {
    rankdir=TB;
    node [shape=box, style=rounded, fontname="PingFang SC"];
    
    // 前端层
    subgraph cluster_frontend {
        label="前端层 (Vue 3 + Vite)";
        style=filled;
        color=lightblue;
        
        Browser [label="浏览器\n(用户界面)", shape=ellipse];
        Static [label="静态资源\n(HTML/CSS/JS)"];
    }
    
    // 网关层
    Nginx [label="Nginx\n反向代理", shape=doublecircle];
    
    // 后端层
    subgraph cluster_backend {
        label="后端层 (Node.js + Express)";
        style=filled;
        color=lightyellow;
        
        API [label="API服务\n(/api/*)"];
        TimeService [label="时间服务\n(Timezone处理)"];
        Auth [label="认证服务\n(JWT)"];
    }
    
    // 数据层
    subgraph cluster_data {
        label="数据层";
        style=filled;
        color=lightgreen;
        
        MySQL [label="MySQL 8.0\n(时区配置)"];
        Redis [label="Redis 8.6\n(缓存)"];
    }
    
    // 关系
    Browser -> Static [label="1.访问"];
    Browser -> Nginx [label="2.请求"];
    Nginx -> API [label="3.转发"];
    API -> TimeService [label="4.业务处理"];
    API -> Auth [label="5.认证"];
    TimeService -> MySQL [label="6.查询配置"];
    TimeService -> Redis [label="7.缓存"];
    Redis -> MySQL [label="8.回源"];
    
    // 标注
    label="世界时钟系统架构图";
    fontsize=16;
}
